{
  "title": "Bharat GPT Enterprise Metrics",
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "targets": [{"expr": "sum(http_requests_total)"}]
    },
    {
      "type": "graph",
      "title": "Request Latency",
      "targets": [{"expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])"}]
    },
    {
      "type": "stat",
      "title": "Authentication Failures",
      "targets": [{"expr": "sum(http_requests_total{status=~\"4.1\"})"}]
    }
  ]
}
